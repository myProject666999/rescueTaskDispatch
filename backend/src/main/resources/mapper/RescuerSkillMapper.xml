<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.rescue.mapper.RescuerSkillMapper">

    <select id="selectByRescuerId" resultType="com.rescue.entity.RescuerSkill">
        SELECT * FROM rescuer_skill
        WHERE rescuer_id = #{rescuerId}
        AND deleted = 0
    </select>

    <select id="selectRescuerIdsBySkillId" resultType="java.lang.Long">
        SELECT rescuer_id FROM rescuer_skill
        WHERE skill_id = #{skillId}
        AND deleted = 0
        <if test="minProficiency != null and minProficiency != ''">
            AND proficiency IN
            <foreach collection="proficiencyList" item="p" open="(" separator="," close=")">
                #{p}
            </foreach>
        </if>
    </select>

</mapper>
