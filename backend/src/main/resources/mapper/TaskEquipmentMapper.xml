<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.rescue.mapper.TaskEquipmentMapper">

    <select id="selectByTaskId" resultType="com.rescue.entity.TaskEquipment">
        SELECT * FROM task_equipment
        WHERE task_id = #{taskId}
        AND deleted = 0
        ORDER BY created_time DESC
    </select>

</mapper>
